# These are auto-provisioned by Netlify on deploy.
# You only need to set these if running locally without `netlify dev`.

# Netlify Blobs (auto-set in Netlify env)
NETLIFY_SITE_ID=
NETLIFY_BLOBS_TOKEN=

# Your agent's API key — generated automatically on first visit.
# Override here only if you want a custom value.
AGENT_HQ_API_KEY=
